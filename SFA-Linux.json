{
  "log": {
    "level": "warn",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "type": "https",
        "tag": "dns-remote",
        "detour": "Proxy",
        "server": "8.8.8.8"
      },
      {
        "type": "https",
        "tag": "dns-direct",
        "server": "8.8.8.8"
      },
      {
        "type": "https",
        "tag": "dns-ech",
        "domain_resolver": "dns-direct",
        "server": "doh.cmliussss.net",
        "path": "CMLiussss"
      }
    ],
    "rules": [
      {
        "query_type": "HTTPS",
        "domain_suffix": "pages.dev",
        "server": "dns-ech"
      },
      {
        "rule_set": "geosite-ir",
        "server": "dns-direct"
      }
    ],
    "strategy": "prefer_ipv4"
  },
  "inbounds": [
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 2080
    }
  ],
  "outbounds": [
    {
      "type": "selector",
      "tag": "Proxy",
      "outbounds": [
        "auto",
        "{all}"
      ]
    },
    {
      "type": "urltest",
      "tag": "auto",
      "outbounds": [
        "{all}"
      ],
      "interval": "10m0s"
    },
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "rules": [
      {
        "ip_cidr": "172.19.0.2",
        "action": "hijack-dns"
      },
      {
        "inbound": [
          "mixed-in"
        ],
        "action": "resolve",
        "strategy": "ipv4_only"
      },
      {
        "inbound": [
          "mixed-in"
        ],
        "action": "sniff",
        "timeout": "1s"
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "rule_set": [
          "geoip-ir",
          "geosite-ir"
        ],
        "outbound": "direct"
      },
      {
        "network": "udp",
        "action": "reject",
        "method": "drop"
      }
    ],
    "rule_set": [
      {
        "type": "remote",
        "tag": "geosite-ir",
        "url": "https://raw.githubusercontent.com/Chocolate4U/Iran-sing-box-rules/rule-set/geosite-ir.srs"
      },
      {
        "type": "remote",
        "tag": "geoip-ir",
        "url": "https://raw.githubusercontent.com/Chocolate4U/Iran-sing-box-rules/rule-set/geoip-ir.srs"
      }
    ],
    "final": "Proxy",
    "auto_detect_interface": true,
    "default_domain_resolver": {
      "server": "dns-direct",
      "strategy": "ipv4_only",
      "rewrite_ttl": 300
    }
  },
    "experimental": {
    "cache_file": {
      "enabled": true
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090"
    }
  }
}
